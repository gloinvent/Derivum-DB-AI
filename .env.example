# Environment / secrets (DO NOT COMMIT REAL KEYS - copy to .env and fill in actual values)

# OpenAI API Key - Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-actual-key-here

# LLM Model to use
LLM_MODEL=gpt-4o

# AWS RDS Database credentials
HOST=your-rds-endpoint.rds.amazonaws.com
PORT=5432
DATABASE=your_database_name
USER=your_db_user
PASSWORD=your_db_password

# Internal API Key for protecting /api/query endpoint
API_KEY=generate-a-random-secure-key-here

# API Tier system
V1_API_KEY=generate-a-random-key-for-v1-api
V1_PLAN_TIER=pro
